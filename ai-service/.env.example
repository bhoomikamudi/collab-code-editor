# AI mode: true = mock responses + deterministic local embeddings (no API key required)
# false = real OpenAI + LangChain embeddings (requires OPENAI_API_KEY)
AI_MOCK_MODE=true

# Legacy alias (optional): USE_MOCK_AI=true is equivalent to AI_MOCK_MODE=true
# USE_MOCK_AI=true

# Required when AI_MOCK_MODE=false
OPENAI_API_KEY=

OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
CHROMA_DB_DIR=/app/chroma_data
CHUNK_TOKEN_LIMIT=500

# Comma-separated origins for CORS (optional)
# CLIENT_URL=http://localhost:3000
