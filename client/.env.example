# Optional Vite env overrides for local development.
# Defaults: API http://localhost:5000, WebSocket ws://localhost:5000
#
# Production builds behind nginx usually leave these empty so the client uses
# same-origin REST routes and /ws for WebSocket upgrades.

# VITE_API_BASE_URL=http://localhost:5000
# VITE_WS_URL=ws://localhost:5000
