# Copy to project root as `.env` for docker compose -f docker-compose.prod.yml
# Do not commit real secrets.

# Public URL of the app (used for CORS on the Node backend)
CLIENT_URL=http://localhost

# Host port exposed by nginx (change if 80 is already in use)
NGINX_HTTP_PORT=80

# PostgreSQL (must match DATABASE_URL credentials)
POSTGRES_USER=collab_user
POSTGRES_PASSWORD=replace_with_a_secure_database_password
POSTGRES_DB=collab_code_editor

# Backend connection strings (use Docker service hostnames)
DATABASE_URL=postgresql://collab_user:replace_with_a_secure_database_password@postgres:5432/collab_code_editor
REDIS_URL=redis://redis:6379

# Auth
JWT_SECRET=replace_with_a_long_random_secret_before_deployment
JWT_EXPIRES_IN=7d

# Optional frontend build overrides for production nginx image.
# Leave empty to use same-origin REST + /ws WebSocket routing through nginx.
VITE_API_BASE_URL=
VITE_WS_URL=

# AI service — AI_MOCK_MODE=true needs no OpenAI key; false requires OPENAI_API_KEY
AI_MOCK_MODE=true
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small
CHUNK_TOKEN_LIMIT=500
